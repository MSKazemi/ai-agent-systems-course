# =============================================================================
# A2A Example - Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# --- LLM Provider Selection ---
# azure  = Use Azure OpenAI (requires Azure env vars below)
# gemini = Use Google Gemini (requires GOOGLE_API_KEY)
# (leave empty = auto: Azure if configured, else Gemini)
LLM_PROVIDER=ollama

# --- Azure OpenAI (when LLM_PROVIDER=azure) ---
# Get these from Azure Portal → your Azure OpenAI resource → Keys and Endpoint
#AZURE_OPENAI_API_KEY=your-azure-openai-api-key
#AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
#AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Deployment name from Azure OpenAI Studio (e.g. gpt-4o)
#AZURE_PRIMARY_LLM_DEPLOYMENT_NAME=gpt-4o

# --- Gemini (when LLM_PROVIDER=gemini) ---
# Get key from https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-google-api-key

# --- Optional: Dynamic coordinator with HTTP registry ---
# If set, dynamic_coordinator fetches agents from this URL instead of agent_registry.json
# Start registry with: uvicorn registry_server:app --port 8004
# REGISTRY_URL=http://127.0.0.1:8004/agents

# --- OLLAMA (when LLM_PROVIDER=ollama) ---
OLLAMA_MODEL=qwen3.5:35b
OLLAMA_BASE_URL=http://localhost:11434