# ─────────────────────────────────────────────────────────────
# AI Agent Systems Course — LLM provider config
#
# Copy this file to .env in the repo root, then fill in the
# section for your chosen provider.
#
#   cp .env.example .env
#
# All course modules read this file automatically.
# ─────────────────────────────────────────────────────────────

# ── Choose one provider ──────────────────────────────────────
LLM_PROVIDER=ollama          # ollama | azure | gemini | openai

# ── Ollama (local — no API key needed, recommended default) ──
OLLAMA_MODEL=qwen3.5:35b
OLLAMA_BASE_URL=http://localhost:11434

# ── Azure OpenAI ─────────────────────────────────────────────
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01

# ── Google Gemini ─────────────────────────────────────────────
# GOOGLE_API_KEY=your-key

# ── OpenAI ───────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── A2A: optional HTTP registry for dynamic coordinator ──────
# REGISTRY_URL=http://127.0.0.1:8004/agents
